<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="1" author="farmrecorder">
        <createTable tableName="locations">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="gln" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="geo_json_polygon" type="text"/>
        </createTable>
    </changeSet>

    <changeSet id="2" author="farmrecorder">
        <createTable tableName="products">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="gtin" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="variety" type="varchar(255)"/>
            <column name="batch_prefix" type="varchar(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="3" author="farmrecorder">
        <createTable tableName="activity_logs">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="timestamp" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="location_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="uuid"/>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="text"/>
            <column name="gps_lat" type="double precision"/>
            <column name="gps_lng" type="double precision"/>
        </createTable>
    </changeSet>

    <changeSet id="4" author="farmrecorder">
        <createTable tableName="media">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="activity_log_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="varchar(1024)">
                <constraints nullable="false"/>
            </column>
            <column name="captured_gps_lat" type="double precision"/>
            <column name="captured_gps_lng" type="double precision"/>
            <column name="timestamp" type="timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="5" author="farmrecorder">
        <createTable tableName="farms">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="owner_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="6" author="farmrecorder">
        <createTable tableName="tasks">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="farm_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_to" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="status" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="timestamp"/>
        </createTable>
    </changeSet>

    <changeSet id="7" author="farmrecorder">
        <addColumn tableName="activity_logs">
            <column name="task_id" type="uuid"/>
        </addColumn>
    </changeSet>

    <changeSet id="8" author="farmrecorder">
        <renameColumn tableName="media" oldColumnName="image_url" newColumnName="media_url" columnDataType="varchar(1024)"/>
        <addColumn tableName="media">
            <column name="media_type" type="varchar(50)" defaultValue="IMAGE">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="9" author="farmrecorder">
        <createTable tableName="harvest_batches">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="location_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="harvested_by_id" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="harvested_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="batch_number" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="initial_quantity" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="remaining_quantity" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="10" author="farmrecorder">
        <addColumn tableName="activity_logs">
            <column name="start_time" type="timestamp"/>
            <column name="end_time" type="timestamp"/>
            <column name="batch_id" type="uuid"/>
            <column name="quantity" type="int"/>
            <column name="unit_price" type="decimal(10,2)"/>
            <column name="total_price" type="decimal(10,2)"/>
            <column name="customer_name" type="varchar(255)"/>
            <column name="customer_phone" type="varchar(50)"/>
            <column name="customer_email" type="varchar(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="11" author="farmrecorder">
        <addColumn tableName="products">
            <column name="default_unit_price" type="decimal(10,2)"/>
        </addColumn>
    </changeSet>

    <changeSet id="12" author="farmrecorder">
        <!-- Add columns to products -->
        <addColumn tableName="products">
            <column name="type" type="varchar(50)" defaultValue="CROP">
                <constraints nullable="false"/>
            </column>
            <column name="epa_registration_number" type="varchar(255)"/>
            <column name="active_ingredients" type="varchar(1024)"/>
            <column name="rei_hours" type="int"/>
            <column name="phi_days" type="int"/>
            <column name="is_local_only" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="admin_notes" type="text"/>
        </addColumn>

        <!-- Add columns to activity_logs -->
        <addColumn tableName="activity_logs">
            <column name="chemical_lot_number" type="varchar(255)"/>
            <column name="chemical_expiration_date" type="timestamp"/>
            <column name="application_rate" type="varchar(255)"/>
            <column name="total_quantity_applied" type="decimal(10,2)"/>
            <column name="weather_wind_speed" type="double precision"/>
            <column name="weather_wind_direction" type="varchar(50)"/>
            <column name="weather_temperature" type="double precision"/>
            <column name="applicator_license" type="varchar(255)"/>
            <column name="is_manual_input" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="manual_input_comments" type="text"/>
            <column name="verification_status" type="varchar(50)" defaultValue="VERIFIED">
                <constraints nullable="false"/>
            </column>
            <column name="verified_by" type="varchar(255)"/>
            <column name="verified_at" type="timestamp"/>
            <column name="rei_end_time" type="timestamp"/>
        </addColumn>
    </changeSet>

    <changeSet id="13" author="farmrecorder">
        <createTable tableName="input_batches">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="gtin" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="lot_number" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="initial_quantity" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="remaining_quantity" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="expiration_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="input_batches" columnNames="gtin,lot_number" constraintName="uq_gtin_lot"/>
    </changeSet>

    <changeSet id="14" author="farmrecorder">
        <createTable tableName="workers">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="full_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="applicator_license" type="varchar(255)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
