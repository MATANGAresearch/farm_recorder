{
  "name": "farm-recorder",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "backend:dev": "cd apps/backend && ./mvnw quarkus:dev",
    "backend:build": "cd apps/backend && ./mvnw clean package",
    "generate:clients": "npm run generate:react-client && npm run generate:flutter-client",
    "generate:react-client": "cd packages/api-contracts && npx orval --config orval.config.ts",
    "generate:flutter-client": "cd packages/api-contracts && npx openapi-generator-cli generate -c openapi-generator-config.json"
  },
  "devDependencies": {
    "nx": "^19.0.0",
    "orval": "^7.0.0",
    "@openapitools/openapi-generator-cli": "^2.13.0"
  }
}
